# Application
APP_NAME=RAG-File-Service
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# PostgreSQL / pgvector
DB_HOST=localhost
DB_PORT=5433
DB_NAME=rag_platform
DB_USER=postgres
DB_PASSWORD=change-me
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# CORS
# If the frontend runs on another host or port, add it here.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Uploads
MAX_UPLOAD_SIZE_MB=20
# Relative UPLOAD_DIR is resolved under the project root by FileService.
UPLOAD_DIR=uploads
ALLOWED_EXTENSIONS=[".pdf",".docx",".txt",".md"]

# Embedding and tokenizer
# MVP local mode loads BAAI/bge-m3 from the project offline cache.
# Supported EMBEDDING_PROVIDER values: local, api, ollama.
EMBEDDING_PROVIDER=local
DEFAULT_EMBEDDING_MODEL=BAAI/bge-m3
DEFAULT_TOKENIZER_MODEL=BAAI/bge-m3
VECTOR_DIMENSION=1024
EMBEDDING_CACHE_DIR=../offline_cache/tokenizers
TOKENIZER_CACHE_DIR=../offline_cache/tokenizers
EMBEDDING_LOCAL_FILES_ONLY=true
TOKENIZER_LOCAL_FILES_ONLY=true
TOKENIZER_STRICT=false
EMBEDDING_NORMALIZE=true

# Future API embedding mode
# Set EMBEDDING_PROVIDER=api and fill these when switching to an internal embedding gateway.
# DEFAULT_EMBEDDING_MODEL is also used as the API embedding model name.
INTERNAL_EMBEDDING_BASE_URL=
INTERNAL_EMBEDDING_API_KEY=
INTERNAL_EMBEDDING_TIMEOUT=60

# Local rerank
# DEFAULT_RERANK_MODEL uses the BGE M3 reranker, not the embedding model.
# Set RERANK_ENABLED=true after caching DEFAULT_RERANK_MODEL locally.
RERANK_ENABLED=false
RERANK_PROVIDER=local
DEFAULT_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_CACHE_DIR=../offline_cache/rerankers
RERANK_LOCAL_FILES_ONLY=true
RERANK_BATCH_SIZE=8
RERANK_MAX_LENGTH=1024

# Ollama embedding mode
# Set EMBEDDING_PROVIDER=ollama and INTERNAL_EMBEDDING_BASE_URL=http://host:11434.
# The client calls /api/embed and reads the "embeddings" response field.

# LightRAG
# Relative to backend/ when uvicorn is started from backend/.
LIGHTRAG_WORKING_DIR=lightrag_storage
LIGHTRAG_CHUNK_TOKEN_SIZE=4096
LIGHTRAG_CHUNK_OVERLAP_TOKEN_SIZE=0
LIGHTRAG_LLM_MODEL_MAX_ASYNC=2
LIGHTRAG_EMBEDDING_FUNC_MAX_ASYNC=2
LIGHTRAG_DEFAULT_EMBEDDING_TIMEOUT=120
LIGHTRAG_DEFAULT_LLM_TIMEOUT=240

# LightRAG query-stage limits.
# Changing these affects future retrieve requests only and does not require re-indexing.
LIGHTRAG_QUERY_CHUNK_TOP_K=10
LIGHTRAG_QUERY_MAX_ENTITY_TOKENS=6000
LIGHTRAG_QUERY_MAX_RELATION_TOKENS=8000
LIGHTRAG_QUERY_MAX_TOTAL_TOKENS=24000

# Optional LightRAG WebUI sidecar.
# This is a debug-only sidecar URL, not the primary business frontend.
LIGHTRAG_WEBUI_URL=http://127.0.0.1:9621/webui

# Retrieve defaults
DEFAULT_TOP_K=5
DEFAULT_THRESHOLD=0.7
DEFAULT_SEARCH_MODE=global

# OpenAI-compatible LLM gateway
# Example base URL: https://api.deepseek.com
INTERNAL_LLM_BASE_URL=https://your-llm-gateway.example.com
INTERNAL_LLM_API_KEY=replace-with-your-api-key
DEFAULT_LLM_MODEL=deepseek-chat
INTERNAL_LLM_TIMEOUT=60
INTERNAL_LLM_MAX_RETRIES=3
# false means httpx ignores HTTP_PROXY/HTTPS_PROXY from the shell environment.
INTERNAL_LLM_TRUST_ENV=false

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=5
SCHEDULER_BATCH_SIZE=100
SCHEDULER_MAX_RETRIES=3
SCHEDULER_RETRY_INTERVAL_MINUTES=30
SCHEDULER_PROCESSING_TIMEOUT_MINUTES=30
# Keep false for normal local runs: indexing is handled by scripts/start_indexer_worker.ps1.
RUN_INDEXER_IN_API=false
INDEXER_WORKER_POLL_SECONDS=3
